# DRiX Dashboard — Environment Variables

# ─── REQUIRED ───────────────────────────────────────────────────────────────────

# PostgreSQL connection (Railway provides this automatically when you add Postgres)
DATABASE_URL=

# DRiX-Leads instance URL (your running DRiX-Leads Railway service)
# Example: https://web-production-d024e.up.railway.app
DRIX_API_URL=

# Service account on DRiX-Leads (register a business email account on your DRiX-Leads app)
# The dashboard uses this to call DRiX-Leads for intelligence processing.
DRIX_API_EMAIL=dashboard@wintechpartners.com
DRIX_API_PASSWORD=

# ─── OPTIONAL ───────────────────────────────────────────────────────────────────

# Session signing secret (auto-generated from DATABASE_URL if not set)
SESSION_SECRET=

# Email notifications via Resend (emails from nick@getthedrix.com)
RESEND_API_KEY=
DASHBOARD_FROM_EMAIL=nick@getthedrix.com

# Public URL of this app (auto-detected on Railway via RAILWAY_PUBLIC_DOMAIN)
APP_URL=

# Port (Railway sets this automatically)
PORT=3100
